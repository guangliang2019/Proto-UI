---
import type { RuntimeId } from './runtimes/registry';

type DemoOption = {
  id: string;
  label: string;
  description?: string;
};

type RuntimeOption = {
  id: RuntimeId;
  label: string;
};

interface Props {
  demos: DemoOption[];
  initialDemoId?: string;
  initialRuntime?: RuntimeId;
  runtimes?: RuntimeOption[];
  id?: string;
  class?: string;
  pickerLabel?: string;
  runtimeLabel?: string;
}

const locale = Astro.locals.starlightRoute.locale;
const copy =
  locale === 'en'
    ? {
        eyebrow: 'Homepage Preview',
        title: 'Try switching runtimes to see whether the component stays consistent.',
        lead: 'Behavior stays consistent, while implementation stays replaceable.',
      }
    : {
        eyebrow: '首页预览',
        title: '尝试切换 runtime，观察组件是否保持一致',
        lead: '行为表现保持一致，实现方式允许替换',
      };

const {
  demos,
  initialDemoId,
  initialRuntime = 'wc',
  runtimes = [
    { id: 'wc', label: 'Web Components' },
    { id: 'react', label: 'React' },
    { id: 'vue', label: 'Vue' },
  ],
  id = 'home-demo-previewer',
  class: className = '',
  pickerLabel = 'Component',
  runtimeLabel = 'Runtime',
} = Astro.props;

if (!Array.isArray(demos) || demos.length === 0) {
  throw new Error('[HomeDemoPreviewer] "demos" must include at least one demo option.');
}

const initialDemo = demos.find((demo) => demo.id === initialDemoId) ?? demos[0];
---

<section
  id={id}
  class:list={['home-demo-previewer', className]}
  data-home-demo-options={JSON.stringify(demos)}
  data-runtime-options={JSON.stringify(runtimes)}
  data-initial-demo-id={initialDemo.id}
  data-initial-runtime={initialRuntime}
>
  <div class="home-demo-previewer__panel">
    <div class="home-demo-previewer__header">
      <div class="home-demo-previewer__intro">
        <p class="home-demo-previewer__intro-eyebrow">{copy.eyebrow}</p>
        <h2 class="home-demo-previewer__intro-title">{copy.title}</h2>
        <p class="home-demo-previewer__description">{copy.lead}</p>
      </div>

      <div class="home-demo-previewer__toolbar">
        <div class="home-demo-previewer__control">
          <label class="home-demo-previewer__label" for="home-demo-picker">{pickerLabel}</label>
          <div class="home-demo-previewer__select-wrap">
            <select id="home-demo-picker" data-home-demo-picker class="home-demo-previewer__select">
            </select>
            <span class="home-demo-previewer__chevron" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-chevron-down-icon lucide-chevron-down"
              >
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </span>
          </div>
        </div>

        <div class="home-demo-previewer__control">
          <label class="home-demo-previewer__label" for="home-demo-runtime">{runtimeLabel}</label>
          <div class="home-demo-previewer__select-wrap">
            <select
              id="home-demo-runtime"
              data-home-demo-runtime
              class="home-demo-previewer__select"
            >
            </select>
            <span class="home-demo-previewer__chevron" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-chevron-down-icon lucide-chevron-down"
              >
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="home-demo-previewer__stage">
      <div class="home-demo-previewer__host" data-home-demo-host></div>
    </div>
  </div>

  <script>
    import { initHomeDemoPreviewer } from './home-demo-client';

    function init() {
      document
        .querySelectorAll<HTMLElement>(
          '.home-demo-previewer[data-home-demo-options]:not([data-inited])'
        )
        .forEach((root) => initHomeDemoPreviewer(root));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</section>

<style>
  .home-demo-previewer {
    width: min(100%, 68rem);
    margin: 0 auto;
    padding: 0 1rem 2.5rem;
    scroll-margin-block: 18vh;
  }

  .home-demo-previewer__panel {
    border: 1px solid color-mix(in oklch, var(--color-border) 86%, transparent);
    border-radius: 1.5rem;
    overflow: hidden;
    background:
      radial-gradient(
        circle at top left,
        color-mix(in oklch, var(--color-accent) 12%, transparent),
        transparent 34%
      ),
      linear-gradient(
        180deg,
        color-mix(in oklch, var(--color-muted) 28%, transparent),
        transparent 40%
      ),
      linear-gradient(
        135deg,
        color-mix(in oklch, var(--color-accent) 5%, transparent),
        transparent 55%
      ),
      var(--color-background);
    box-shadow:
      0 16px 48px color-mix(in oklch, black 10%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 55%, transparent);
  }

  :global([data-theme='dark']) .home-demo-previewer__panel {
    box-shadow:
      0 20px 56px color-mix(in oklch, black 22%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 10%, transparent);
  }

  .home-demo-previewer__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    padding: 1.25rem 1.25rem 0;
  }

  .home-demo-previewer__intro {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
    padding: 0.15rem 0 0;
  }

  .home-demo-previewer__intro-eyebrow {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--color-foreground) 68%, var(--color-accent) 32%);
  }

  .home-demo-previewer__intro-title {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.3;
    font-weight: 600;
    color: var(--color-foreground);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }

  .home-demo-previewer__toolbar {
    display: grid;
    grid-template-columns: minmax(0, 10rem) minmax(0, 11.5rem);
    gap: 0.65rem;
    align-self: start;
  }

  .home-demo-previewer__control {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .home-demo-previewer__label {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--color-foreground) 52%, var(--color-muted-foreground) 48%);
  }

  .home-demo-previewer__select-wrap {
    position: relative;
  }

  .home-demo-previewer__select {
    width: 100%;
    appearance: none;
    border: 1px solid var(--color-border);
    border-radius: 0.8rem;
    background: color-mix(in oklch, var(--color-background) 94%, var(--color-muted) 6%);
    color: var(--color-foreground);
    font-size: 0.88rem;
    padding: 0.7rem 2rem 0.7rem 0.85rem;
    outline: none;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }

  .home-demo-previewer__select:hover {
    background: color-mix(in oklch, var(--color-background) 86%, var(--color-muted) 14%);
  }

  .home-demo-previewer__select:focus-visible {
    border-color: var(--color-ring);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-ring) 18%, transparent);
  }

  .home-demo-previewer__chevron {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted-foreground);
    pointer-events: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .home-demo-previewer__chevron svg {
    width: 1rem;
    height: 1rem;
  }

  .home-demo-previewer__description {
    margin: 0;
    max-width: 42rem;
    color: var(--color-muted-foreground);
    font-size: 0.92rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }

  .home-demo-previewer__stage {
    position: relative;
    padding: 1.25rem;
  }

  .home-demo-previewer__host {
    min-height: 20rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border-radius: 1.15rem;
    border: 1px solid color-mix(in oklch, var(--color-border) 88%, transparent);
    background: var(--color-background);
    box-shadow:
      inset 0 1px 0 color-mix(in oklch, white 18%, transparent),
      0 1px 0 color-mix(in oklch, var(--color-border) 24%, transparent);
    padding: 1.5rem;
  }

  :global([data-theme='dark']) .home-demo-previewer__host {
    background: var(--color-background);
    box-shadow:
      inset 0 1px 0 color-mix(in oklch, white 6%, transparent),
      0 1px 0 color-mix(in oklch, black 14%, transparent);
  }

  .home-demo-previewer__host > :global(*) {
    max-width: 100%;
    margin-inline: auto;
  }

  @media (max-width: 720px) {
    .home-demo-previewer {
      padding-inline: 0.75rem;
      padding-bottom: 1.5rem;
    }

    .home-demo-previewer__header {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .home-demo-previewer__toolbar {
      grid-template-columns: 1fr;
    }

    .home-demo-previewer__host {
      min-height: 16rem;
      padding: 1rem;
    }
  }
</style>
