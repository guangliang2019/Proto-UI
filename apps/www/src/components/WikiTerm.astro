---
import { getWikiHref, getWikiTerm, type WikiLocale } from '../data/wiki-terms';

interface Props {
  slug: string;
  label?: string;
  summary?: string;
  href?: string;
  locale?: WikiLocale;
}

const { slug, label, summary, href, locale: localeProp } = Astro.props as Props;

const routeLocale = Astro.locals.starlightRoute.locale === 'en' ? 'en' : 'zh-cn';
const locale = localeProp ?? routeLocale;
const entry = getWikiTerm(locale, slug);
const termLabel = label ?? entry?.term[locale] ?? slug;
const termSummary = summary ?? entry?.summary[locale] ?? '';
const termHref = href ?? getWikiHref(locale, slug);
const instanceId = `wiki-term-${slug}-${Math.random().toString(36).slice(2, 10)}`;
---

<span
  class="wiki-term"
  data-wiki-term
  data-copy-success={locale === 'zh-cn' ? '已复制' : 'Copied'}
  data-term-href={termHref}
  id={instanceId}
>
  <a
    class="wiki-term__trigger"
    href={termHref}
    aria-expanded="false"
    aria-controls={`${instanceId}-card`}
  >
    <slot>{termLabel}</slot>
  </a>
  <span class="wiki-term__card" role="note" id={`${instanceId}-card`}>
    <span class="wiki-term__eyebrow">{locale === 'zh-cn' ? 'Wiki' : 'Wiki'}</span>
    <span class="wiki-term__title">{termLabel}</span>
    {termSummary && <span class="wiki-term__summary">{termSummary}</span>}
    <span class="wiki-term__actions">
      <button
        class="wiki-term__action wiki-term__copy"
        type="button"
        data-copy-text={`${termLabel}\n\n${termSummary}`.trim()}
      >
        {locale === 'zh-cn' ? '复制卡片' : 'Copy card'}
      </button>
      <a class="wiki-term__action wiki-term__link" href={termHref}>
        {locale === 'zh-cn' ? '前往词条' : 'Open entry'}
      </a>
    </span>
  </span>
</span>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!(root instanceof HTMLElement) || !root.matches('[data-wiki-term]')) return;
    if (!root) return;
    const trigger = root.querySelector('.wiki-term__trigger');
    const copy = root.querySelector('.wiki-term__copy');
    if (!(trigger instanceof HTMLAnchorElement)) return;

    const setPinned = (next) => {
      root.dataset.pinned = next ? 'true' : 'false';
      trigger.setAttribute('aria-expanded', next ? 'true' : 'false');
    };

    trigger.addEventListener('click', (event) => {
      const href = root.dataset.termHref || trigger.getAttribute('href') || '';
      if (!href) return;

      // Keep link semantics for SEO and modifier-click behavior.
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) {
        return;
      }

      if (root.dataset.pinned === 'true') {
        setPinned(false);
        window.location.assign(href);
        return;
      }

      event.preventDefault();
      setPinned(true);
    });

    document.addEventListener('click', (event) => {
      if (!root.contains(event.target)) setPinned(false);
    });

    root.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setPinned(false);
    });

    if (copy instanceof HTMLButtonElement) {
      copy.addEventListener('click', async () => {
        const text = copy.dataset.copyText || '';
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
          const previous = copy.textContent;
          copy.textContent = root.dataset.copySuccess || previous || '';
          window.setTimeout(() => {
            copy.textContent = previous;
          }, 1200);
        } catch {}
      });
    }
  })();
</script>

<style>
  .wiki-term {
    position: relative;
    display: inline-flex;
    vertical-align: baseline;
  }

  .wiki-term__trigger {
    display: inline;
    color: var(--color-foreground);
    border-bottom: 1px dashed color-mix(in oklab, var(--color-primary) 60%, transparent);
    background: linear-gradient(
        to top,
        color-mix(in oklab, var(--color-primary) 10%, transparent) 0%,
        color-mix(in oklab, var(--color-primary) 10%, transparent) 100%
      )
      0 100% / 100% 0.45em no-repeat;
    transition:
      border-color 180ms ease,
      background-size 180ms ease,
      color 180ms ease;
    text-decoration: none;
  }

  .wiki-term__trigger:hover,
  .wiki-term__trigger:focus-visible {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    background-size: 100% 0.8em;
    outline: none;
  }

  .wiki-term__card {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.7rem);
    z-index: 40;
    width: min(20rem, calc(100vw - 2rem));
    min-width: 16rem;
    translate: -50% 0.35rem;
    border: 1px solid color-mix(in oklab, var(--color-border) 88%, transparent);
    border-radius: 1rem;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-background) 92%, white 8%),
      color-mix(in oklab, var(--color-background) 98%, black 2%)
    );
    box-shadow:
      0 18px 40px rgba(15, 23, 42, 0.12),
      0 2px 10px rgba(15, 23, 42, 0.08);
    padding: 0.9rem 1rem 0.95rem;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 180ms ease,
      translate 180ms ease;
  }

  [data-theme='dark'] .wiki-term__card {
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-background) 88%, white 4%),
      color-mix(in oklab, var(--color-background) 94%, black 6%)
    );
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.4),
      0 2px 10px rgba(0, 0, 0, 0.28);
  }

  .wiki-term:hover .wiki-term__card,
  .wiki-term:focus-within .wiki-term__card,
  .wiki-term[data-pinned='true'] .wiki-term__card {
    opacity: 1;
    pointer-events: auto;
    translate: -50% 0;
  }

  .wiki-term__eyebrow {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--color-muted-foreground);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .wiki-term__title {
    display: block;
    color: var(--color-foreground);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .wiki-term__summary {
    display: block;
    margin-top: 0.45rem;
    color: var(--color-muted-foreground);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .wiki-term__actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.7rem;
    flex-wrap: wrap;
  }

  .wiki-term__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    border-radius: 999px;
    padding: 0 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
  }

  .wiki-term__copy {
    appearance: none;
    border: 1px solid color-mix(in oklab, var(--color-border) 86%, transparent);
    background: color-mix(in oklab, var(--color-muted) 72%, transparent);
    color: var(--color-foreground);
    cursor: pointer;
  }

  .wiki-term__link {
    color: var(--color-primary);
    background: color-mix(in oklab, var(--color-primary) 12%, transparent);
  }

  @media (max-width: 640px) {
    .wiki-term__card {
      left: 0;
      min-width: min(16rem, calc(100vw - 2rem));
      width: min(18rem, calc(100vw - 2rem));
      translate: 0 0.35rem;
    }

    .wiki-term:hover .wiki-term__card,
    .wiki-term:focus-within .wiki-term__card {
      translate: 0 0;
    }

    .wiki-term[data-pinned='true'] .wiki-term__card {
      translate: 0 0;
    }
  }
</style>
