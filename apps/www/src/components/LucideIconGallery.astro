---
import { LUCIDE_ICON_MANIFEST } from '@proto.ui/prototypes-lucide/manifest';

type Locale = 'en' | 'zh-cn';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props as Props;

const copy =
  locale === 'zh-cn'
    ? {
        searchLabel: '搜索图标',
        searchPlaceholder: '输入图标名，例如 chevron',
        listSummaryPrefix: '当前显示',
        listSummarySuffix: '个图标',
        copyAsHook: '复制 asHook',
        copyRender: '复制 render',
        copied: '已复制',
        empty: '没有匹配的图标。',
        close: '关闭',
        importPath: '导入路径',
      }
    : {
        searchLabel: 'Search icons',
        searchPlaceholder: 'Type icon name, e.g. chevron',
        listSummaryPrefix: 'Showing',
        listSummarySuffix: 'icons',
        copyAsHook: 'Copy asHook',
        copyRender: 'Copy render',
        copied: 'Copied',
        empty: 'No icons match your query.',
        close: 'Close',
        importPath: 'Import path',
      };

const icons = [...LUCIDE_ICON_MANIFEST].sort((a, b) => a.name.localeCompare(b.name));
---

<section class="lucide-gallery" data-lucide-gallery>
  <div class="lucide-gallery__toolbar">
    <label class="lucide-gallery__search" for={`lucide-search-${locale}`}>
      <span>{copy.searchLabel}</span>
      <input
        id={`lucide-search-${locale}`}
        type="search"
        placeholder={copy.searchPlaceholder}
        autocomplete="off"
        data-icon-search
      />
    </label>

    <p class="lucide-gallery__summary">
      {copy.listSummaryPrefix}
      <strong data-visible-count>{icons.length}</strong>
      {copy.listSummarySuffix}
    </p>
  </div>

  <div class="lucide-gallery__grid" data-icon-grid>
    {
      icons.map((icon) => (
        <button
          type="button"
          class="lucide-card"
          data-icon-card
          data-icon-name={icon.name}
          data-import-path={icon.importPath}
          data-as-hook-export={icon.asHookExport}
          data-render-export={icon.renderExport}
          aria-label={`icon ${icon.name}`}
          title={icon.name}
        >
          <span class="lucide-card__preview" data-icon-preview aria-hidden="true">
            <span class="lucide-card__placeholder">{icon.name[0]?.toUpperCase()}</span>
          </span>
        </button>
      ))
    }
  </div>

  <p class="lucide-gallery__empty" data-empty hidden>{copy.empty}</p>

  <div class="lucide-modal" data-icon-modal hidden>
    <button class="lucide-modal__backdrop" type="button" data-modal-close aria-label={copy.close}
    ></button>

    <section
      class="lucide-modal__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`lucide-modal-title-${locale}`}
      tabindex="-1"
    >
      <header class="lucide-modal__header">
        <h3 id={`lucide-modal-title-${locale}`} data-modal-title></h3>
        <button type="button" class="lucide-modal__close" data-modal-close aria-label={copy.close}
          >×</button
        >
      </header>

      <div class="lucide-modal__body">
        <div class="lucide-modal__preview" data-modal-preview></div>
        <p class="lucide-modal__path-label">{copy.importPath}</p>
        <code class="lucide-modal__path" data-modal-import-path></code>
      </div>

      <footer class="lucide-modal__actions">
        <button
          type="button"
          data-modal-copy-kind="asHook"
          data-label={copy.copyAsHook}
          data-copied-label={copy.copied}
        >
          {copy.copyAsHook}
        </button>
        <button
          type="button"
          data-modal-copy-kind="render"
          data-label={copy.copyRender}
          data-copied-label={copy.copied}
        >
          {copy.copyRender}
        </button>
      </footer>
    </section>
  </div>
</section>

<script>
  import { loadLucideIconShape } from '@proto.ui/prototypes-lucide/loaders';

  const SVG_NS = 'http://www.w3.org/2000/svg';
  const SHAPE_TAGS = new Set(['path', 'circle', 'line', 'rect', 'polyline', 'ellipse', 'polygon']);
  const shapeCache = new Map();
  const shapeLoading = new Map();

  function toPascalCase(value) {
    return value
      .split(/[^a-zA-Z0-9]+/)
      .filter(Boolean)
      .map((chunk) => chunk[0].toUpperCase() + chunk.slice(1))
      .join('');
  }

  function toKebabCase(value) {
    return value.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
  }

  function createShapeFactories() {
    const make = (tag, attrs = {}) => ({ tag, attrs });
    return {
      path: (attrs) => make('path', attrs),
      circle: (attrs) => make('circle', attrs),
      line: (attrs) => make('line', attrs),
      rect: (attrs) => make('rect', attrs),
      polyline: (attrs) => make('polyline', attrs),
      ellipse: (attrs) => make('ellipse', attrs),
      polygon: (attrs) => make('polygon', attrs),
    };
  }

  function appendShapeNode(parent, node) {
    if (!node) return;
    if (Array.isArray(node)) {
      node.forEach((child) => appendShapeNode(parent, child));
      return;
    }
    if (typeof node !== 'object') return;

    const tag = node.tag;
    if (!SHAPE_TAGS.has(tag)) return;

    const element = document.createElementNS(SVG_NS, tag);
    const attrs = node.attrs || {};
    for (const [key, value] of Object.entries(attrs)) {
      if (value == null || value === false) continue;
      const attrName = toKebabCase(key);
      if (value === true) {
        element.setAttribute(attrName, '');
      } else {
        element.setAttribute(attrName, String(value));
      }
    }
    parent.appendChild(element);
  }

  function createIconSvg(shapeFactory, size = 20) {
    const svg = document.createElementNS(SVG_NS, 'svg');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('width', String(size));
    svg.setAttribute('height', String(size));
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', 'currentColor');
    svg.setAttribute('stroke-width', '2');
    svg.setAttribute('stroke-linecap', 'round');
    svg.setAttribute('stroke-linejoin', 'round');
    svg.setAttribute('aria-hidden', 'true');

    const nodes = shapeFactory(createShapeFactories());
    appendShapeNode(svg, nodes);
    return svg;
  }

  function findShapeFactory(moduleExports) {
    for (const [key, value] of Object.entries(moduleExports)) {
      if (key.endsWith('_SHAPE_FACTORY') && typeof value === 'function') {
        return value;
      }
    }
    return null;
  }

  async function getShapeFactory(iconName) {
    if (shapeCache.has(iconName)) return shapeCache.get(iconName);
    if (shapeLoading.has(iconName)) return shapeLoading.get(iconName);

    const task = loadLucideIconShape(iconName)
      .then((mod) => findShapeFactory(mod))
      .catch((error) => {
        console.error('[LucideIconGallery] failed to load icon shape:', iconName, error);
        return null;
      })
      .then((factory) => {
        shapeCache.set(iconName, factory);
        shapeLoading.delete(iconName);
        return factory;
      });

    shapeLoading.set(iconName, task);
    return task;
  }

  function snippetForCard(card, kind) {
    const iconName = card.dataset.iconName || '';
    const importPath = card.dataset.importPath || `@proto.ui/prototypes-lucide/icons/${iconName}`;
    const asHookExport = card.dataset.asHookExport || `asLucide${toPascalCase(iconName)}Icon`;
    const renderExport = card.dataset.renderExport || `renderLucide${toPascalCase(iconName)}Icon`;

    if (kind === 'render') {
      return `import { ${renderExport} } from '${importPath}';\n\nreturn (renderer) =>\n  renderer.el('span', [\n    ${renderExport}(renderer, { size: 16, strokeWidth: 2 }),\n  ]);`;
    }

    return `import { definePrototype } from '@proto.ui/core';\nimport { ${asHookExport}, ${renderExport} } from '${importPath}';\n\nconst iconLikeTrigger = definePrototype({\n  name: 'my-trigger',\n  setup() {\n    ${asHookExport}();\n    return (renderer) => [\n      renderer.r.slot(),\n      ${renderExport}(renderer, { size: 16 }),\n    ];\n  },\n});`;
  }

  function flashCopied(button) {
    const normal = button.dataset.label || button.textContent || 'Copy';
    const copied = button.dataset.copiedLabel || 'Copied';
    button.textContent = copied;
    window.setTimeout(() => {
      button.textContent = normal;
    }, 1400);
  }

  async function copySnippet(card, button, kind) {
    const text = snippetForCard(card, kind);
    try {
      await navigator.clipboard.writeText(text);
      flashCopied(button);
    } catch {
      button.textContent = button.dataset.label || button.textContent || 'Copy';
    }
  }

  async function fillPreview(preview, iconName, size) {
    if (!(preview instanceof HTMLElement)) return false;
    const shapeFactory = await getShapeFactory(iconName);
    preview.textContent = '';
    if (!shapeFactory) {
      preview.textContent = '!';
      return false;
    }
    preview.appendChild(createIconSvg(shapeFactory, size));
    return true;
  }

  async function ensureIconLoaded(card) {
    if (card.dataset.iconLoaded === '1' || card.dataset.iconLoading === '1') return;

    const iconName = card.dataset.iconName;
    const preview = card.querySelector('[data-icon-preview]');
    if (!iconName || !(preview instanceof HTMLElement)) return;

    card.dataset.iconLoading = '1';
    const ok = await fillPreview(preview, iconName, 20);
    card.dataset.iconLoaded = ok ? '1' : 'error';
    delete card.dataset.iconLoading;
  }

  function initSearch(root) {
    const input = root.querySelector('[data-icon-search]');
    const cards = Array.from(root.querySelectorAll('[data-icon-card]'));
    const empty = root.querySelector('[data-empty]');
    const count = root.querySelector('[data-visible-count]');

    if (!(input instanceof HTMLInputElement) || cards.length === 0) return;

    const apply = () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const name = (card.dataset.iconName || '').toLowerCase();
        const shown = query.length === 0 || name.includes(query);
        card.hidden = !shown;
        if (shown) visible += 1;
      });

      if (empty instanceof HTMLElement) {
        empty.hidden = visible > 0;
      }
      if (count instanceof HTMLElement) {
        count.textContent = String(visible);
      }
    };

    input.addEventListener('input', apply);
    apply();
  }

  function initLazyLoad(root) {
    const cards = Array.from(root.querySelectorAll('[data-icon-card]'));
    if (cards.length === 0) return;

    if (typeof IntersectionObserver === 'undefined') {
      cards.forEach((card) => {
        if (card instanceof HTMLElement) {
          void ensureIconLoaded(card);
        }
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const card = entry.target;
          observer.unobserve(card);
          if (card instanceof HTMLElement) {
            void ensureIconLoaded(card);
          }
        });
      },
      { rootMargin: '220px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }

  function initModal(root) {
    const modal = root.querySelector('[data-icon-modal]');
    const panel = modal?.querySelector('.lucide-modal__panel');
    const preview = modal?.querySelector('[data-modal-preview]');
    const title = modal?.querySelector('[data-modal-title]');
    const importPath = modal?.querySelector('[data-modal-import-path]');

    if (!(modal instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;
    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    let activeCard = null;

    const close = () => {
      if (modal.hidden) return;
      modal.hidden = true;
      document.body.style.removeProperty('overflow');
      if (activeCard instanceof HTMLElement) {
        activeCard.focus();
      }
    };

    const open = async (card) => {
      const iconName = card.dataset.iconName;
      if (!iconName) return;

      activeCard = card;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      if (title instanceof HTMLElement) {
        title.textContent = iconName;
      }
      if (importPath instanceof HTMLElement) {
        importPath.textContent = card.dataset.importPath || '';
      }

      if (preview instanceof HTMLElement) {
        preview.textContent = '';
        const ok = await fillPreview(preview, iconName, 48);
        if (!ok) {
          preview.textContent = '!';
        }
      }

      panel.focus();
    };

    root.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const card = target.closest('[data-icon-card]');
      if (card instanceof HTMLElement && root.contains(card)) {
        void open(card);
      }
    });

    modal.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const closeBtn = target.closest('[data-modal-close]');
      if (closeBtn && modal.contains(closeBtn)) {
        close();
        return;
      }

      const copyBtn = target.closest('button[data-modal-copy-kind]');
      if (copyBtn && copyBtn instanceof HTMLButtonElement) {
        if (!(activeCard instanceof HTMLElement)) return;
        const kind = copyBtn.dataset.modalCopyKind === 'render' ? 'render' : 'asHook';
        void copySnippet(activeCard, copyBtn, kind);
      }
    });

    modal.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) {
        close();
      }
    });
  }

  function initGallery(root) {
    if (root.dataset.galleryInit === '1') return;
    root.dataset.galleryInit = '1';

    initSearch(root);
    initLazyLoad(root);
    initModal(root);
  }

  function initAll() {
    document.querySelectorAll('[data-lucide-gallery]').forEach((root) => {
      if (root instanceof HTMLElement) {
        initGallery(root);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll, { once: true });
  } else {
    initAll();
  }

  document.addEventListener('astro:page-load', initAll);
</script>

<style>
  .lucide-gallery {
    display: grid;
    gap: 1rem;
  }

  .lucide-gallery__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .lucide-gallery__search {
    display: grid;
    gap: 0.35rem;
    min-width: min(24rem, 100%);
  }

  .lucide-gallery__search span {
    font-size: 0.8125rem;
    color: var(--sl-color-text-secondary);
  }

  .lucide-gallery__search input {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.625rem;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
  }

  .lucide-gallery__summary {
    font-size: 0.85rem;
    color: var(--sl-color-text-secondary);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .lucide-gallery__summary strong {
    color: var(--sl-color-text);
    font-variant-numeric: tabular-nums;
  }

  .lucide-gallery__grid {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(8, minmax(0, 1fr));
  }

  .lucide-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.55rem;
    background: color-mix(in oklch, var(--sl-color-gray-7) 45%, transparent);
    padding: 0.45rem 0.4rem;
    display: grid;
    gap: 0.3rem;
    justify-items: center;
    align-content: start;
    cursor: pointer;
    transition:
      border-color 150ms ease,
      background-color 150ms ease,
      transform 150ms ease;
  }

  .lucide-card:hover {
    border-color: var(--sl-color-accent);
    background: color-mix(in oklch, var(--sl-color-accent) 10%, var(--sl-color-bg-nav));
    transform: translateY(-1px);
  }

  .lucide-card:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 1px;
  }

  .lucide-card__preview {
    width: 100%;
    min-height: 2.25rem;
    border-radius: 0.45rem;
    border: 1px dashed var(--sl-color-gray-5);
    background: color-mix(in oklch, var(--sl-color-gray-6) 24%, transparent);
    display: grid;
    place-items: center;
    color: var(--sl-color-text);
  }

  .lucide-card__placeholder {
    font-size: 0.86rem;
    color: var(--sl-color-text-tertiary);
    font-weight: 500;
  }

  .lucide-gallery__empty {
    margin: 0;
    font-size: 0.9rem;
    color: var(--sl-color-text-secondary);
  }

  .lucide-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .lucide-modal__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgb(6 8 12 / 58%);
    cursor: pointer;
  }

  .lucide-modal__panel {
    position: relative;
    width: min(28rem, 100%);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.85rem;
    background: var(--sl-color-bg-nav);
    box-shadow: 0 22px 65px rgb(0 0 0 / 35%);
    padding: 0.9rem;
    display: grid;
    gap: 0.75rem;
  }

  .lucide-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .lucide-modal__header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--sl-color-text);
  }

  .lucide-modal__close {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    width: 2rem;
    height: 2rem;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
  }

  .lucide-modal__body {
    display: grid;
    gap: 0.5rem;
  }

  .lucide-modal__preview {
    min-height: 6rem;
    border-radius: 0.7rem;
    border: 1px dashed var(--sl-color-gray-5);
    background: color-mix(in oklch, var(--sl-color-gray-6) 24%, transparent);
    display: grid;
    place-items: center;
    color: var(--sl-color-text);
  }

  .lucide-modal__path-label {
    margin: 0;
    font-size: 0.75rem;
    color: var(--sl-color-text-tertiary);
  }

  .lucide-modal__path {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.45rem;
    padding: 0.45rem 0.55rem;
    font-size: 0.72rem;
    color: var(--sl-color-text-secondary);
    background: var(--sl-color-bg);
    word-break: break-all;
  }

  .lucide-modal__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .lucide-modal__actions button {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.55rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.5rem 0.6rem;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .lucide-modal__actions button:hover {
    border-color: var(--sl-color-accent);
    background: color-mix(in oklch, var(--sl-color-accent) 12%, var(--sl-color-bg));
  }

  @media (max-width: 1180px) {
    .lucide-gallery__grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .lucide-gallery__grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .lucide-gallery__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .lucide-gallery__toolbar {
      align-items: stretch;
    }

    .lucide-gallery__search {
      min-width: 100%;
    }

    .lucide-gallery__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .lucide-gallery__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lucide-modal {
      padding: 0.6rem;
    }

    .lucide-modal__panel {
      padding: 0.7rem;
    }
  }
</style>
