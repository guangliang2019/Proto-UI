{
  "name": "apps-www",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "generate:prototype-tokens": "node ./scripts/generate-prototype-tailwind-sources.mjs",
    "generate:setup:shadcn:cli": "proto-ui shadcn --styles-dir ./src/styles",
    "generate:prototype-tokens:cli": "proto-ui tokens --input ../../packages/prototypes --out ./src/styles/prototype-tokens.generated.css",
    "generate:tailwindcss:cli": "proto-ui tailwindcss --out ./src/styles/tailwindcss.css --theme-import ./shadcn-theme.css --tokens-import ./prototype-tokens.generated.css",
    "generate:theme:shadcn:cli": "proto-ui theme shadcn --out ./src/styles/shadcn-theme.css",
    "generate-code": "tsx scripts/example_code_generation/cli.ts",
    "dev": "pnpm run generate:prototype-tokens && astro dev",
    "start": "pnpm run dev",
    "build": "pnpm run generate:prototype-tokens && astro build && node ./scripts/clean-sitemap.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/starlight": "^0.35.2",
    "@proto.ui/adapter-react": "workspace:*",
    "@proto.ui/adapter-vue": "workspace:*",
    "@proto.ui/adapter-web-component": "workspace:*",
    "@proto.ui/core": "workspace:*",
    "@proto.ui/types": "workspace:*",
    "@proto.ui/module-presence": "workspace:*",
    "@proto.ui/prototypes-base": "workspace:*",
    "@proto.ui/prototypes-lucide": "workspace:*",
    "@proto.ui/prototypes-shadcn": "workspace:*",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "^5.6.1",
    "sharp": "^0.34.2",
    "shiki": "^3.22.0",
    "tailwindcss": "^4.1.11",
    "unist-util-visit": "^5.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "prettier": "^3.8.1",
    "@types/mdast": "^4.0.0",
    "mdast-util-mdx": "^3.0.0",
    "remark-mdx": "^3.0.0",
    "remark-parse": "^11.0.0",
    "tsx": "^4.0.0",
    "unified": "^11.0.0"
  }
}
