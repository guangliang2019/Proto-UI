{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@proto.ui/module-*": ["packages/modules/*/src"],
      "@proto.ui/adapter-*": ["packages/adapters/*/src"],
      "@proto.ui/prototypes-base": ["packages/prototypes/base/src/index.ts"],
      "@proto.ui/prototypes-shadcn": ["packages/prototypes/shadcn/src/index.ts"],
      "@proto.ui/prototypes-*": ["packages/prototypes/*/src"],
      "@proto.ui/*": [
        "packages/*/src",
        "packages/modules/*/src",
        "packages/adapters/*/src",
        "packages/legacy/*/src"
      ]
    },
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
